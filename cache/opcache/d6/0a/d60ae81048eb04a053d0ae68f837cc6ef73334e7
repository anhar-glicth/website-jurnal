";s:29:"emails.userRoleEndNotify.body";s:727:"<div class='email-container'>    <div class='email-header'>        <h2>Uklanjanje korisničke uloge</h2>    </div>    <div class='email-content'>        <p>Poštovani/Poštovana {$recipientName},</p>        <p>Zahvaljujemo Vam na sudjelovanju u ulozi {$roleRemoved} u {$contextName}.</p>        <p>Ovom Vas porukom obavještavamo da Vam je uklonjena sljedeća uloga u {$contextName}: <b>{$roleRemoved}</b>.</p>        <p>Vaš račun u {$contextName} je i dalje aktivan, kao i sve druge uloge koje ste ranije imali.</p>        <p>Slobodno nas kontaktirajte ako imate bilo kakvih pitanja u vezi s ovim postupkom.</p>        <p>Srdačan pozdrav,</p>        <p>{$contextName}</p>    </div></div><style>{$emailTemplateStyle}</style>";s:31:"mailable.userRoleEndNotify.name";s:38:"Obavijest o ukidanju korisničke uloge";s:49:"emails.changeProfileEmailInvitationNotify.subject";s:36:"Potvrdi promjenu e-pošte za kontakt";s:53:"emails.changeProfileEmailInvitationNotify.description";s:76:"Ova se poruka šalje korisnicima koji zatraže promjenu svoje e-mail adrese.";s:35:"emails.orcidCollectAuthorId.subject";s:12:"ORCID autora";s:39:"emails.orcidCollectAuthorId.description";s:67:"Ova se poruka šalje radi prikupljanja ORCID identifikatora autora.";s:46:"emails.orcidRequestAuthorAuthorization.subject";s:32:"Zahtjev za pristup ORCID profilu";s:50:"emails.orcidRequestAuthorAuthorization.description";s:67:"Ova se poruka šalje radi zahtjeva za pristup ORCID profilu autora.";s:42:"emails.orcidRequestUpdateScope.description";s:94:"Ova se poruka šalje kada je potrebno zatražiti ažuriranje OAuth dosega za ORCID Member API.";s:37:"emailTemplate.variable.authorOrcidUrl";s:37:"Poveznica za ORCID OAuth autorizaciju";s:36:"emailTemplate.variable.orcidAboutUrl";s:35:"URL stranice o ORCID identifikatoru";s:34:"orcid.orcidRequestUpdateScope.name";s:23:"orcidRequestUpdateScope";s:38:"mailable.userRoleEndNotify.description";s:54:"Poruka koju dobivaju korisnici kada im se ukine uloga.";s:32:"emails.userRoleEndNotify.subject";s:32:"Korisnička uloga Vam je ukinuta";s:46:"emailTemplate.variable.userRoleEnd.roleRemoved";s:48:"Ovo je naziv korisničke uloge koja je uklonjena";}}}