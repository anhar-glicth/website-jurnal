1809724299a:3:{s:6:"domain";N;s:12:"plural-forms";s:26:"nplurals=2; plural=n != 1;";s:8:"messages";a:1:{s:0:"";a:102:{s:35:"emails.orcidCollectAuthorId.subject";s:22:"Материал ORCID";s:68:"emails.userRoleAssignmentInvitationNotify.userGroupSectionEndingDate";s:37:"Аяктоо датасы: {$dateEnd}";s:60:"emails.userRoleAssignmentInvitationNotify.newlyAssignedRoles";s:60:"<p><h2>Жаңы дайындалган ролдор</h2></p>";s:62:"emails.userRoleAssignmentInvitationNotify.alreadyAssignedRoles";s:68:"<p><h2>Мурунтан дайындалган ролдор</h2></p>";s:47:"emailTemplate.variable.invitation.recipientName";s:51:"Чакырууну алган адамдын аты";s:45:"emailTemplate.variable.invitation.inviterName";s:57:"Чакырууну жөнөткөн адамдын аты";s:45:"emailTemplate.variable.invitation.inviterRole";s:59:"Чакырууну жөнөткөн адамдын ролу";s:24:"emails.reviewAck.subject";s:44:"Рецензияңыз үчүн рахмат";s:25:"emails.discussion.subject";s:44:"{$contextName} боюнча билдирүү";s:49:"emails.changeProfileEmailInvitationNotify.subject";s:124:"Аккаунттун байланыш электрондук дарегин өзгөртүү өтүнүчүн ырастоо";s:53:"emails.changeProfileEmailInvitationNotify.description";s:161:"Бул электрондук кат электрондук дарегин өзгөртүүнү сураган колдонуучуларга жөнөтүлөт.";s:46:"emails.changeProfileEmailInvitationNotify.body";s:813:"<p>Урматтуу {$recipientName},</p><p>Бул электрондук катты алып жатасыз, анткени кимдир бирөө электрондук дарегиңизди {$newEmail} дарегине өзгөртүүнү сурады.</p><p>Эгер бул өтүнүчтү өзүңүз жасаган болсоңуз, электрондук даректи өзгөртүүнү <a href="{$acceptInvitationUrl}">ырастоо</a>.</p><p>Ар дайым бул өзгөртүүнү <a href="{$declineInvitationUrl}">четке кагууга</a> болот.</p><p>Материал же рецензия процесси боюнча суроолоруңуз болсо, мени менен байланышсаңыз болот.</p><p>Саламаттык менен,</p>{$siteContactName}";s:35:"emails.orcidRequestUpdateScope.body";s:1676:"Урматтуу {$recipientName},<br>
